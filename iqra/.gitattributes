# Normalize line endings and avoid CRLF/LF noise across platforms
* text=auto

# Source code uses LF in repo
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Binaries
*.exe binary
*.pdb binary
*.rlib binary
